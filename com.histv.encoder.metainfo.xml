<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.histv.encoder</id>
  <name>Honey, I Shrunk The Vids</name>
  <summary>Batch video encoder with smart bitrate decisions</summary>
  <developer id="com.histv">
    <name>obelisk-complex</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      A cross-platform batch video encoder that shrinks your video files to a
      target quality level. Pick a target bitrate, add your files, and hit start.
      The app figures out what to do with each file automatically.
    </p>
    <p>
      Supports GPU-accelerated encoding (AMF, NVENC, QSV, VAAPI, VideoToolbox),
      HDR preservation and tonemapping, Dolby Vision and HDR10+ passthrough,
      animated WebP/GIF/APNG conversion, AV1 encoding, precision mode with CRF
      quality targeting, and 25+ input formats.
    </p>
  </description>

  <url type="homepage">https://github.com/obelisk-complex/histv-universal</url>
  <url type="bugtracker">https://github.com/obelisk-complex/histv-universal/issues</url>

  <launchable type="desktop-id">com.histv.encoder.desktop</launchable>

  <provides>
    <binary>histv</binary>
  </provides>

  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

