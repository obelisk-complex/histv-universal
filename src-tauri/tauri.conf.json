{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Honey I Shrunk The Vids",
  "version": "2.1.0",
  "identifier": "com.histv.encoder",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
	"withGlobalTauri": true,
    "windows": [
      {
        "title": "Honey, I Shrunk The Vids",
        "width": 1100,
        "height": 580,
        "minWidth": 900,
        "minHeight": 780,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "themes/*"
    ]
  },
  "plugins": {}
}
